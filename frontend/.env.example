# Copy this file to `.env` in the same folder (frontend/) if you removed `.env`, then fill in values.

# Directory (tenant) ID — Entra ID → Overview → Tenant ID (GUID). NOT the client ID.
MICROSOFT_TENANT_ID=
# Application (client) ID — App registrations → your app → Application (client) ID
MICROSOFT_CLIENT_ID=
# MICROSOFT_REDIRECT_URI=http://localhost:8080/
